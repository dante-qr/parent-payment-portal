{
	"formatter": {
		"language_server": {
			"name": "biome"
		}
	},
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": true
			}
		},
		"vscode-css-language-server": {
			"settings": {
				"css": {
					"lint": {
						"unknownAtRules": "ignore"
					}
				}
			}
		}
	},
	"code_actions_on_format": {
		"source.fixAll.biome": true,
		"source.organizeImports.biome": true
	}
}
