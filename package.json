{
	"version": "1.0.0",
	"name": "payments-collector",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check --diagnostic-level=error",
		"types": "tsc --noEmit",
		"prepare": "husky",
		"commit": "cz",
		"release": "npx --package semantic-release --package @semantic-release/changelog --package @semantic-release/git semantic-release",
		"release:dry": "npm run release -- --dry-run",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"db:start": "docker compose up -d",
		"db:watch": "docker compose up",
		"db:stop": "docker compose stop",
		"db:down": "docker compose down"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@fontsource-variable/geist": "^5.2.9",
		"@orpc/client": "^1.14.7",
		"@orpc/openapi": "^1.14.7",
		"@orpc/server": "^1.14.7",
		"@orpc/tanstack-query": "^1.14.7",
		"@orpc/zod": "^1.14.7",
		"@shadcn/react": "^0.2.1",
		"@t3-oss/env-core": "^0.13.11",
		"@tailwindcss/vite": "^4",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-form": "^1.33.1",
		"@tanstack/react-query-devtools": "^5.101.2",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "latest",
		"better-auth": "^1.6.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^1.0.0-rc.4",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.24.0",
		"next-themes": "^0.4.6",
		"nitro": "^3.0.260603-beta",
		"pg": "^8.22.0",
		"react": "^19.2.6",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.6",
		"react-resizable-panels": "^4.12.1",
		"recharts": "3.8.0",
		"shadcn": "^4.13.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22",
		"@types/pg": "^8.20.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"drizzle-kit": "^1.0.0-rc.4",
		"husky": "^9.1.7",
		"jsdom": "^28",
		"lint-staged": "^16.4.0",
		"tsx": "^4.23.0",
		"typescript": "^6",
		"vite": "^8",
		"vitest": "^4"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
